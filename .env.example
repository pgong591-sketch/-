# 财务数据仓库 - 环境变量配置

# 数据库类型: sqlite / postgresql
DB_TYPE=sqlite

# SQLite 数据库路径（默认: data/finance_dw.db）
# FINANCE_DW_DB_PATH=data/finance_dw.db

# PostgreSQL 配置（DB_TYPE=postgresql 时使用）
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=finance_dw

# SQL 日志（true/false）
SQL_ECHO=false
